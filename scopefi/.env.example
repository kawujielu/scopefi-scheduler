# 复制为 scopefi/.env 并填写实际值
# cp .env.example .env

# ScopeFi Track API
SCOPEFI_TRACK_BASE_URL=https://api.scopefi.ai
SCOPEFI_API_KEY=
SCOPEFI_POSITION_PATH=/api/track/user/position
SCOPEFI_POSITION_TIMEOUT_SEC=15

# Lark 异常通知（lark_notice.py）
LARK_PROJECT_NAME=scopefi-scheduler
LARK_NOTICE_PATH=/api/internal/send/notice
LARK_NOTICE_TIMEOUT_SEC=15
LARK_NOTICE_ERROR_TITLE=REST接口异常
LARK_NOTICE_ERROR_TYPE=error

# ClickHouse（scopefi/.env，docker compose 挂载）
CLICKHOUSE_HOST=192.168.112.239
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=writer_pro
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=pro
